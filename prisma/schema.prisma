// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  password      String
  role          String   @default("user") // admin | manager | user
  profileImg    String?
  geminiApiKey  String?  // encrypted
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  apps     AppCard[]
  posts    Post[]
  comments Comment[]
  likes    AppLike[]
}

model AppCard {
  id                String   @id @default(cuid())
  title             String
  thumbnail         String   @default("/placeholder-app.svg")
  description       String
  detailDescription String?
  link              String
  industryTags      String   // JSON array stored as string
  processTags       String   // JSON array stored as string
  hasGeminiDemo     Boolean  @default(false)
  likeCount         Int      @default(0)
  createdBy         String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  author User      @relation(fields: [createdBy], references: [id])
  likes  AppLike[]
}

model Post {
  id        String   @id @default(cuid())
  type      String   // notice | forum | job | article
  title     String
  content   String
  isPinned  Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author   User      @relation(fields: [authorId], references: [id])
  comments Comment[]
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  postId    String
  authorId  String
  createdAt DateTime @default(now())

  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])
}

model TagOption {
  id        String   @id @default(cuid())
  type      String   // industry | process
  label     String
  createdAt DateTime @default(now())

  @@unique([type, label])
}

model AppLike {
  userId    String
  appId     String
  createdAt DateTime @default(now())

  user User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  app  AppCard @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@id([userId, appId])
}
